DATABASE_URL="postgresql://todomaster:todomaster@localhost:5432/todomaster"
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
PORT=3000
CORS_ORIGIN="http://localhost:5173"

# Public URL of the web app — used to build links in verification emails
# (e.g. `${WEB_APP_URL}/verify-email?token=...`).
WEB_APP_URL="http://localhost:5173"

# Gmail SMTP for verification / password-reset emails. Leave SMTP_USER empty in
# dev — the mailer falls back to logging emails to the console instead of
# sending (see mailer.service.ts). To send real mail: enable 2-Step Verification
# on the Gmail account, generate an "App Password" at
# https://myaccount.google.com/apppasswords, and use that (not the account
# password) as SMTP_APP_PASSWORD.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER=""
SMTP_APP_PASSWORD=""
SMTP_FROM="ToDoMaster <no-reply@todomaster.app>"
